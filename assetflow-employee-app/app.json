{
  "expo": {
    "name": "AssetFlow",
    "slug": "assetflow-employee-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "assetflow",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "AssetFlow uses the camera to scan QR codes on assets.",
        "NSPhotoLibraryUsageDescription": "AssetFlow accesses your photo library to attach images to tickets.",
        "NSMicrophoneUsageDescription": "Required by the camera module."
      }
    },
    "android": {
      "package": "com.assetflow.mobileapp",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "AssetFlow accesses photos to attach to tickets.",
          "cameraPermission": "AssetFlow uses the camera to photograph issues for tickets."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090b",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
